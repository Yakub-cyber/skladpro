# Скопируйте в .env и подставьте значения.

# Собственный бэкенд SkladPro (skladpro-backend).
# Локально: http://localhost:8787
# Продакшен: https://api.skladpro.ru
# Оставьте пустым — приложение работает в офлайн-режиме без облака.
VITE_API_URL=http://localhost:8787

# Ключ ProxyAPI (OpenAI) для облачного ИИ. Необязателен: без него ИИ работает
# локально (эвристики). ТОЛЬКО для локальной разработки — не встраивайте ключ
# в публичную сборку, иначе он утечёт. В проде вводится в Настройках приложения.
VITE_AI_KEY=

# Sentry DSN для мониторинга ошибок (пусто = мониторинг выключен)
VITE_SENTRY_DSN=

# ── УСТАРЕЛО (осталось для истории миграции; больше не используется) ─────
# VITE_SUPABASE_URL=
# VITE_SUPABASE_KEY=
