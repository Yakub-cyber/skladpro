# Скопируйте в .env и подставьте значения.

# Supabase → Settings → API (для облачного мультитенанта; можно не задавать)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_KEY=sb_publishable_xxxxxxxx

# Ключ ProxyAPI (OpenAI) для облачного ИИ. Необязателен: без него ИИ работает
# локально (эвристики). ТОЛЬКО для локальной разработки — не встраивайте ключ
# в публичную сборку, иначе он утечёт. В проде вводится в Настройках приложения.
VITE_AI_KEY=
